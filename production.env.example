# Copy to a protected production secret store; never commit a populated version.
CRYPBOT_ENVIRONMENT=production
CRYPBOT_EXECUTION_MODE=MOCK
CRYPBOT_LIVE_TRADING_ENV_ENABLED=false
CRYPBOT_SEED_DEMO_USERS=false
CRYPBOT_PRODUCTION_BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
CRYPBOT_JWT_SECRET=replace-with-a-long-random-secret-from-a-secret-manager
CRYPBOT_CREDENTIAL_MASTER_KEY=replace-with-a-kms-managed-32-byte-key
CRYPBOT_DATABASE_URL=postgresql+psycopg://crypbot:replace-me@postgres:5432/crypbot
CRYPBOT_REDIS_URL=redis://redis:6379/0
