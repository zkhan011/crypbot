CRYPBOT_ENVIRONMENT=development
CRYPBOT_EXECUTION_MODE=MOCK
CRYPBOT_DATABASE_URL=postgresql+psycopg://crypbot:crypbot@postgres:5432/crypbot
CRYPBOT_REDIS_URL=redis://redis:6379/0
CRYPBOT_JWT_SECRET=replace-with-local-random-secret
CRYPBOT_CREDENTIAL_MASTER_KEY=replace-with-32-byte-local-master-key
CRYPBOT_LIVE_TRADING_ENV_ENABLED=false
